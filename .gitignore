# ========== Git LFS 管理说明 ==========
# 大文件（*.bag, *.pth.tar, *.ply, *.gif, *.pdf等）由 Git LFS 管理
# 本文件只忽略不需要版本控制的文件

# ========== 数据/LFS 不提交（修改代码时不更新 LFS）==========
# 以下为数据文件，日常提交只提交代码/配置，不提交 LFS 数据

# data/ 目录全部为数据，不提交、不推送、不占用仓库空间
data/
automap_pro/src/modular/**/model/
automap_pro/src/modular/**/demo/scans/
automap_pro/src/modular/**/examples/example_data/
automap_pro/src/modular/**/test/teaser/data/
automap_pro/src/modular/**/test/benchmark/data/
automap_pro/src/modular/**/Supplementary/
automap_pro/src/modular/**/*.gif
automap_pro/src/modular/**/*.ply
automap_pro/src/modular/**/*.pcd
automap_pro/src/modular/**/*.bin
automap_pro/thrid_party/**/docs/*.gif
docker/*.tar
docker/*.tar.gz

# ========== Docker 依赖（构建产物，可重新下载）==========
docker/deps/downloads/
docker/deps/*/bin/
docker/deps/*/lib/
docker/deps/*/include/
docker/deps/*/share/
docker/deps/*/build/

# ========== 临时文件 ==========
*.log
logs/*
!logs/README.md
*.tmp
*.swp
*~
.DS_Store
Thumbs.db
*.bak
*.backup
*.orig

# ========== IDE 和编辑器 ==========
.vscode/
.idea/
*.iml
*.code-workspace

# ========== Python ==========
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
build/
dist/
*.egg-info/

# ========== C/C++ ==========
*.o
*.a
*.so
*.dylib
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
compile_commands.json

# ========== 测试和覆盖率 ==========
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ========== 系统文件 ==========
*.cache
*.pid

# ========== ROS2 工作空间构建产物（不提交）==========
automap_ws/install/
automap_ws/install_deps/
automap_ws/build/
automap_ws/build_*/
automap_ws/log/
automap_ws/logs/

# ========== 大模型和第三方库（不提交）==========
automap_pro/thrid_party/libtorch/
automap_pro/thrid_party/libtorch.zip
automap_pro/models/
automap_pro/thrid_party/Sophus/
automap_pro/thrid_party/ceres-solver/
automap_pro/thrid_party/gtsam/
automap_pro/thrid_party/tinyply/

# ========== 子模块工作目录修改 ==========
docker/deps/Livox-SDK2/
docker/deps/Open3D/
docker/deps/TEASER-plusplus/
docker/deps/gtsam/
docker/deps/ikd-Tree/
docker/deps/onnxruntime/
