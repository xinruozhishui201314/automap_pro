# ========== Git LFS 管理说明 ==========
# 大文件（*.bag, *.pth.tar, *.ply, *.gif, *.pdf等）由 Git LFS 管理
# 本文件只忽略不需要版本控制的文件

# ========== Docker 依赖（构建产物，可重新下载）==========
# Docker 下载的二进制依赖
docker/deps/downloads/
docker/deps/*/bin/
docker/deps/*/lib/
docker/deps/*/include/
docker/deps/*/share/

# 第三方库构建产物
docker/deps/*/build/

# ========== 临时文件 ==========
*.log
*.tmp
*.swp
*~
.DS_Store
Thumbs.db
*.bak
*.backup
*.orig

# ========== IDE 和编辑器 ==========
.vscode/
.idea/
*.iml
*.code-workspace

# ========== Python ==========
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
build/
dist/
*.egg-info/

# ========== C/C++ ==========
*.o
*.a
*.so
*.dylib
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
compile_commands.json

# ========== 测试和覆盖率 ==========
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ========== 系统文件 ==========
*.cache
*.pid

# ========== 子模块工作目录修改 ==========
# Git 子模块的修改通常不需要提交
docker/deps/Livox-SDK2/
docker/deps/Open3D/
docker/deps/TEASER-plusplus/
docker/deps/gtsam/
docker/deps/ikd-Tree/
thrid_party/ceres-solver/
