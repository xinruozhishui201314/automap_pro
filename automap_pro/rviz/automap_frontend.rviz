Panels:
  - Class: rviz_common/Displays
    Name: Displays
  - Class: rviz_common/Views
    Name: Views
Visualization Manager:
  Class: ""
  Displays:
    # ═══════════════════════════════════════════════════════════════
    # 前端 RViz：仅显示 LIO/前端信息（轨迹、点云、TF）
    # Fast-LIVO：/path 与 /cloud_registered 的 header.frame_id 均为 camera_init，位姿与点云同属「IMU/世界」系（LIVMapper::_state.pos_end + RGBpointBodyToWorld）。
    # Fixed Frame 使用 camera_init：与消息一致，不依赖 map↔camera_init 静态 TF，避免误以为「轨迹与点云不同系」。
    # 同屏「backend global map」为 frame_id=map；launch 仍发布 map→camera_init 恒等 TF，可与前端叠加。回环/HBA 后后端轨迹/图与前端 LIO 形状可能不一致属正常。
    # 说明：当前 LIVMapper 中 /Laser_map 的 publisher 可能未实际 publish（见代码检索）；前端稠密图更可靠看 /cloud_registered。
    # ═══════════════════════════════════════════════════════════════
    - Class: rviz_default_plugins/Grid
      Enabled: true
      Name: map grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 50
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: rviz_default_plugins/Axes
      Enabled: true
      Length: 3
      Name: map frame
      Radius: 0.15
      Reference Frame: <Fixed Frame>
    - Class: rviz_default_plugins/TF
      Enabled: true
      Frame Timeout: 15
      Frames:
        All Enabled: true
      Marker Scale: 0.5
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: true
      Tree:
        {}
      Update Interval: 0
      Value: true

    # 前端累积地图（fast_livo 发布 /Laser_map）- 体素下采样后发布，清晰可辨；RViz 适度点大小
    - Alpha: 0.92
      Autocompute Value Bounds: true
      Class: rviz_default_plugins/PointCloud2
      Color: 135; 206; 250
      Decay Time: 0
      Enabled: true
      Name: frontend map
      Size (m): 0.06
      Style: Points
      Topic:
        Depth: 1
        Reliability Policy: Reliable
        Value: /Laser_map
      Use Fixed Frame: true

    # 前端 LIO 点云（fast_livo 输出）- 降密度：Points 样式 + 大点 + 单帧缓冲
    - Alpha: 1
      Autocompute Value Bounds: true
      Class: rviz_default_plugins/PointCloud2
      Color: 239; 80; 80
      Decay Time: 0.2
      Enabled: true
      Name: front LIO cloud
      Size (m): 0.03
      Style: Points
      Topic:
        Depth: 1
        Reliability Policy: Reliable
        Value: /cloud_registered
      Use Fixed Frame: true

    # 前端 LIO 轨迹（/path 由 fast_livo 发布）
    - Alpha: 1
      Class: rviz_default_plugins/Path
      Color: 255; 165; 0
      Enabled: true
      Line Width: 0.07999999821186066
      Name: front path
      Topic:
        Depth: 5
        Reliability Policy: Reliable
        Value: /path
      Use Fixed Frame: true

    # 后端全局地图（可选：全栈运行时显示）- 体素下采样发布；RViz 点略大便于区分结构
    - Alpha: 0.88
      Autocompute Value Bounds: true
      Class: rviz_default_plugins/PointCloud2
      Color: 100; 200; 100
      Decay Time: 0
      Enabled: true
      Name: backend global map
      Size (m): 0.06
      Style: Points
      Topic:
        Depth: 1
        Reliability Policy: Reliable
        Value: /automap/global_map
      Use Fixed Frame: true
  Global Options:
    Background Color: 48; 48; 48
    Fixed Frame: camera_init
  Name: ""
  Tools:
    - Class: rviz_default_plugins/Interact
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 80
      Name: Current View
      Pitch: 0.4
      Yaw: 0.6
    Saved: ~
