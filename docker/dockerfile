# ==========================================================================
# AutoMap-Pro Runtime Environment
# ROS2 Humble + CUDA 11.8 + 全部依赖库
#
# 用途: 纯运行/编译环境, 源码通过 -v 挂载进容器
# 构建: docker build -t automap-env:humble .
#
# 构建时间预计: 30-45 分钟 (取决于网络和机器性能)
# 镜像大小: ~8-10 GB
# ==========================================================================

FROM nvidia/cuda:11.8.0-cudnn8-devel-ubuntu22.04

RUN echo "" && \
    echo "========================================" && \
    echo "AutoMap-Pro Docker 镜像构建开始" && \
    echo "========================================" && \
    echo "基础镜像: nvidia/cuda:11.8.0-cudnn8-devel-ubuntu22.04" && \
    echo "ROS 版本: Humble" && \
    echo "CUDA 版本: 11.8" && \
    echo "" && \
    echo "主要组件:" && \
    echo "  - ROS2 Humble (桌面完整版)" && \
    echo "  - PyTorch 2.1.2 (CUDA 11.8)" && \
    echo "  - Open3D 0.18.0" && \
    echo "  - GTSAM, Sophus, ikd-Tree, TEASER++" && \
    echo "  - Livox SDK" && \
    echo "========================================" && \
    echo ""

# --- 基础环境变量 ---
ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    TZ=Asia/Shanghai \
    ROS_DISTRO=humble \
    CUDA_HOME=/usr/local/cuda \
    PATH=/usr/local/cuda/bin:$PATH \
    LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics

RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 1.1] 安装系统基础工具" && \
    echo "========================================" && \
    apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    ninja-build \
    ccache \
    git \
    wget \
    curl \
    unzip \
    pkg-config \
    software-properties-common \
    lsb-release \
    gnupg2 \
    ca-certificates \
    apt-transport-https \
    python3 \
    python3-dev \
    python3-pip \
    python3-setuptools \
    python3-wheel \
    python3-numpy \
    vim \
    sudo \
    gdb \
    && rm -rf /var/lib/apt/lists/* && \
    echo "✓ 系统基础工具安装完成"

# ==========================================================================
# 安装 CMake 3.24.0 和 ISPC 1.16.1（本地拷贝，避免构建时下载）
# ==========================================================================
RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 0.1] 配置 CMake 和 ISPC" && \
    echo "========================================"

ENV CMAKE_VERSION=3.24.0
ENV CMAKE_DIR=/opt/cmake-${CMAKE_VERSION}
ENV ISPC_DIR=/opt/ispc

# 拷贝本地预下载的 CMake 和 ISPC
COPY ./deps/cmake ${CMAKE_DIR}
COPY ./deps/ispc ${ISPC_DIR}

# 配置 PATH 和环境变量
ENV PATH=${CMAKE_DIR}/bin:${ISPC_DIR}/bin:${PATH}
ENV ISPC=${ISPC_DIR}/bin/ispc
ENV CMAKE_ISPC_COMPILER=${ISPC_DIR}/bin/ispc

# 验证安装
RUN echo "" && \
    echo "验证 CMake 和 ISPC 安装:" && \
    cmake --version && \
    ispc --version && \
    echo "" && \
    echo "✓ CMake and ISPC 安装成功"

# ==========================================================================
# 2. ROS2 Humble (完整桌面版 + 开发工具)
# ==========================================================================
RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 2.1] 配置 ROS2 Humble 源" && \
    echo "========================================" && \
    curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
      -o /usr/share/keyrings/ros-archive-keyring.gpg && \
    echo "✓ ROS2 GPG 密钥添加完成" && \
    echo "deb [arch=$(dpkg --print-architecture) \
      signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] \
      http://packages.ros.org/ros2/ubuntu \
      $(. /etc/os-release && echo $UBUNTU_CODENAME) main" \
      > /etc/apt/sources.list.d/ros2.list && \
    echo "✓ ROS2 源配置完成"

RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 2.2] 安装 ROS2 Humble" && \
    echo "========================================" && \
    echo "预计安装时间: 5-10 分钟" && \
    echo "" && \
    apt-get update && apt-get install -y --no-install-recommends \
    # 核心
    ros-humble-desktop-full \
    ros-dev-tools \
    python3-colcon-common-extensions \
    python3-rosdep \
    python3-vcstool \
    python3-argcomplete \
    # 感知相关
    ros-humble-perception \
    ros-humble-pcl-ros \
    ros-humble-pcl-conversions \
    ros-humble-cv-bridge \
    ros-humble-image-transport \
    ros-humble-compressed-image-transport \
    ros-humble-image-transport-plugins \
    # TF
    ros-humble-tf2 \
    ros-humble-tf2-ros \
    ros-humble-tf2-eigen \
    ros-humble-tf2-geometry-msgs \
    ros-humble-tf2-sensor-msgs \
    # 消息类型
    ros-humble-geographic-msgs \
    ros-humble-nmea-msgs \
    ros-humble-diagnostic-msgs \
    ros-humble-visualization-msgs \
    # DDS (大点云传输优化)
    ros-humble-rmw-cyclonedds-cpp \
    # 可视化
    ros-humble-rviz2 \
    ros-humble-rviz-common \
    ros-humble-rviz-default-plugins \
    ros-humble-foxglove-bridge \
    ros-humble-rqt \
    ros-humble-rqt-graph \
    ros-humble-rqt-topic \
    ros-humble-rqt-tf-tree \
    # rosbag
    ros-humble-rosbag2 \
    ros-humble-rosbag2-storage-mcap \
    && rm -rf /var/lib/apt/lists/* && \
    echo "✓ ROS2 Humble 安装完成"

# rosdep (已禁用 - 当前所有依赖均通过 apt/git 直接安装，不需要 rosdep)
# 如需启用，请取消注释以下代码（注意：国内网络可能需要镜像加速）
# RUN rosdep init 2>/dev/null || true && rosdep update --rosdistro=$ROS_DISTRO

RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 3.1] 安装 C++ 核心依赖库" && \
    echo "========================================" && \
    echo "包括: Eigen3, PCL, OpenCV, Boost, Ceres, 等" && \
    echo "预计安装时间: 3-5 分钟" && \
    echo "" && \
    apt-get update && apt-get install -y --no-install-recommends \
    # Eigen3
    libeigen3-dev \
    # PCL (完整)
    libpcl-dev \
    # OpenCV (含 contrib)
    libopencv-dev \
    # Boost
    libboost-all-dev \
    # Ceres Solver
    libceres-dev \
    # Google 日志/命令行
    libgoogle-glog-dev \
    libgflags-dev \
    # 线性代数后端
    libatlas-base-dev \
    liblapack-dev \
    liblapacke-dev \
    libblas-dev \
    libsuitesparse-dev \
    libmetis-dev \
    # 并行计算
    libtbb-dev \
    # 序列化/配置
    libyaml-cpp-dev \
    libjsoncpp-dev \
    libfmt-dev \
    libspdlog-dev \
    # 地理坐标 (GPS 处理)
    libgeographiclib-dev \
    geographiclib-tools \
    # FLANN (PCL 依赖)
    libflann-dev \
    # HDF5
    libhdf5-dev \
    # 图像编解码
    libjpeg-dev \
    libjpeg-turbo8-dev \
    libpng-dev \
    libtiff-dev \
    # 压缩与网络
    zlib1g-dev \
    libzmq3-dev \
    libcurl4-openssl-dev \
    libssl-dev \
    # 其他
    libglew-dev \
    libglfw3-dev \
    libassimp-dev \
    libembree-dev \
    && rm -rf /var/lib/apt/lists/* && \
    echo "✓ C++ 核心依赖库安装完成"

# GeographicLib 数据文件
RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 3.2] 安装 GeographicLib 数据文件" && \
    echo "========================================" && \
    geographiclib-get-geoids egm96-5 2>/dev/null || true && \
    geographiclib-get-magnetic emm2015 2>/dev/null || true && \
    echo "✓ GeographicLib 数据文件安装完成"

# ==========================================================================
# 4. 源码编译安装: GTSAM 4.2
#    依赖方: HBA, MS-Mapping (核心), Fast-LIVO2 (部分分支)
# ==========================================================================

RUN echo "========================================" && \
    echo "[阶段 4.1] 编译 GTSAM 4.2" && \
    echo "========================================" && \
    echo "预计编译时间: 5-10 分钟" && \
    echo ""

COPY ./deps/gtsam /tmp/gtsam
RUN cd /tmp/gtsam && mkdir build && cd build && \
    cmake .. \
      -DCMAKE_BUILD_TYPE=Release \
      -DCMAKE_INSTALL_PREFIX=/usr/local \
      -DGTSAM_BUILD_TESTS=OFF \
      -DGTSAM_BUILD_EXAMPLES_ALWAYS=OFF \
      -DGTSAM_BUILD_UNSTABLE=ON \
      -DGTSAM_BUILD_PYTHON=OFF \
      -DGTSAM_USE_SYSTEM_EIGEN=ON \
      -DGTSAM_WITH_TBB=ON \
      -DGTSAM_BUILD_WITH_MARCH_NATIVE=OFF && \
    echo "" && \
    echo "开始编译 (使用 $(nproc) 个线程)..." && \
    make -j$(nproc) && \
    echo "✓ GTSAM 编译完成" && \
    make install && \
    ldconfig && \
    echo "✓ GTSAM 安装完成" && \
    rm -rf /tmp/gtsam

# ==========================================================================
# 5. 源码编译安装: Sophus (非模板化版本)
#    依赖方: Fast-LIVO2, MS-Mapping
# ==========================================================================
RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 5.1] 编译 Sophus" && \
    echo "========================================" && \
    echo "预计编译时间: 1-2 分钟" && \
    echo ""

COPY ./deps/Sophus /tmp/Sophus
RUN cd /tmp/Sophus && mkdir build && cd build && \
    cmake .. \
      -DCMAKE_BUILD_TYPE=Release \
      -DCMAKE_INSTALL_PREFIX=/usr/local \
      -DBUILD_SOPHUS_TESTS=OFF \
      -DBUILD_PYTHON_BINDINGS=OFF \
      -DSOPHUS_INSTALL=ON && \
    echo "开始编译..." && \
    make -j$(nproc) && \
    echo "✓ Sophus 编译完成" && \
    make install && ldconfig && \
    echo "✓ Sophus 安装完成" && \
    rm -rf /tmp/Sophus

# ==========================================================================
# 6. 源码编译安装: ikd-Tree (增量KD树)
#    依赖方: Fast-LIVO2 核心依赖
#    说明: IKFoM 为 header-only 库，当前 Fast-LIVO2 未使用，故不安装
# ==========================================================================
RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 6.1] 编译 ikd-Tree" && \
    echo "========================================" && \
    echo "预计编译时间: 1-2 分钟" && \
    echo ""

COPY ./deps/ikd-Tree /tmp/ikd-Tree
RUN cd /tmp/ikd-Tree && mkdir build && cd build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release && \
    echo "开始编译..." && \
    make -j$(nproc) && \
    echo "✓ ikd-Tree 编译完成" && \
    make install && ldconfig && \
    echo "✓ ikd-Tree 安装完成" && \
    rm -rf /tmp/ikd-Tree
# ==========================================================================
# 7. 源码编译安装: Livox-SDK2
#    依赖方: Fast-LIVO2 (Livox 雷达驱动)
# ==========================================================================
RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 7.1] 编译 Livox-SDK2" && \
    echo "========================================" && \
    echo "预计编译时间: 2-3 分钟" && \
    echo ""

COPY ./deps/Livox-SDK2 /tmp/Livox-SDK2
RUN cd /tmp/Livox-SDK2 && mkdir build && cd build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release && \
    echo "开始编译..." && \
    make -j$(nproc) && \
    echo "✓ Livox-SDK2 编译完成" && \
    make install && ldconfig && \
    echo "✓ Livox-SDK2 安装完成" && \
    rm -rf /tmp/Livox-SDK2

# ==========================================================================
# 8. livox_ros_driver2 (ROS2 驱动)
#    依赖方: Fast-LIVO2 (消息类型 + 驱动)
#    说明: livox_ros_driver2 必须在 ROS2 工作空间中使用 colcon 编译
#          已移除预编译步骤，改为运行时编译（见 scripts/build_ros2_drivers.sh）
# ==========================================================================

# ==========================================================================
# 9. 源码编译安装: TEASER++ (C++ 库 + Python Binding)
#    依赖方: 回环精匹配模块
# ==========================================================================
RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 9.1] 编译 pmc (TEASER++ 依赖)" && \
    echo "========================================" && \
    echo "预计编译时间: 1-2 分钟" && \
    echo ""

# pmc (Parallel Maximum Clique — TEASER++ 可选依赖)
COPY ./deps/pmc /tmp/pmc
RUN cd /tmp/pmc && mkdir build && cd build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release && \
    echo "开始编译 pmc..." && \
    make -j$(nproc) && \
    echo "✓ pmc 编译完成" && \
    make install && ldconfig && \
    echo "✓ pmc 安装完成" && \
    rm -rf /tmp/pmc

RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 9.2] 编译 TEASER++" && \
    echo "========================================" && \
    echo "预计编译时间: 3-5 分钟" && \
    echo ""

# TEASER++
COPY ./deps/TEASER-plusplus /tmp/TEASER-plusplus
# 复制本地 pmc 源码到 TEASER-plusplus，避免构建时从 GitHub 下载
COPY ./deps/pmc /tmp/TEASER-plusplus/teaser/pmc-src
# 复制本地 tinyply 源码到 TEASER-plusplus，避免 FetchContent 拉取 GitHub 超时（GnuTLS/连接超时）
COPY ./deps/tinyply /tmp/TEASER-plusplus/teaser/tinyply-src
RUN cd /tmp/TEASER-plusplus && mkdir build && cd build && \
    cmake .. \
      -DCMAKE_BUILD_TYPE=Release \
      -DCMAKE_INSTALL_PREFIX=/usr/local \
      -DBUILD_TESTS=OFF \
      -DBUILD_PYTHON_BINDINGS=ON \
      -DBUILD_DOC=OFF \
      -DBUILD_WITH_MARCH_NATIVE=OFF \
      -DENABLE_DIAGNOSTIC_PRINT=OFF && \
    echo "开始编译 TEASER++..." && \
    make -j$(nproc) && \
    echo "✓ TEASER++ 编译完成" && \
    make install && ldconfig && \
    echo "✓ TEASER++ C++ 库安装完成" && \
    echo "" && \
    echo "安装 Python binding..." && \
    # Python binding - manually install compiled module to avoid scikit-build-core packaging conflicts
    python3 -c "import site; print(site.getsitepackages()[0])" > /tmp/site_packages.txt && \
    SITE_PACKAGES=$(cat /tmp/site_packages.txt) && \
    mkdir -p ${SITE_PACKAGES}/teaserpp_python && \
    cp /tmp/TEASER-plusplus/build/python/teaserpp_python/_teaserpp*.so ${SITE_PACKAGES}/teaserpp_python/ && \
    echo "from ._teaserpp import *" > ${SITE_PACKAGES}/teaserpp_python/__init__.py && \
    echo "✓ TEASER++ Python binding 安装完成" && \
    rm -f /tmp/site_packages.txt && \
    rm -rf /tmp/TEASER-plusplus

# ==========================================================================
# 10. Python 依赖
#     覆盖: OverlapTransformer (PyTorch), TEASER++ Python, Open3D, 评估工具
#     说明: Open3D 通过 pip 安装（包含 CUDA 11.8 支持），避免重复安装
#           TEASER++ 需要 Open3D 的 FPFH 特征提取和点云处理功能
# ==========================================================================

# 配置国内 PyPI 镜像源（加速下载）
RUN echo "========================================" && \
    echo "[阶段 10.1] 配置 PyPI 镜像源" && \
    echo "========================================" && \
    mkdir -p ~/.pip && \
    cat > ~/.pip/pip.conf << 'EOF'
[global]
index-url = https://pypi.tuna.tsinghua.edu.cn/simple
trusted-host = pypi.tuna.tsinghua.edu.cn
timeout = 120
retries = 3
EOF \
    && cat ~/.pip/pip.conf && \
    echo "✓ PyPI 镜像源配置完成"

RUN echo "========================================" && \
    echo "[阶段 10.2] 升级 pip" && \
    echo "========================================" && \
    pip3 install --no-cache-dir --upgrade pip && \
    echo "✓ pip 升级完成" && \
    echo "" && \
    echo "========================================" && \
    echo "[阶段 10.3] 安装 PyTorch (CUDA 11.8)" && \
    echo "========================================" && \
    echo "预计下载大小: ~2.4 GB" && \
    echo "预计安装时间: 5-10 分钟" && \
    echo "" && \
    pip3 install --no-cache-dir --ignore-installed \
      # === PyTorch (CUDA 11.8) — OverlapTransformer 核心依赖 ===
      torch==2.1.2+cu118 \
      torchvision==0.16.2+cu118 \
      torchaudio==2.1.2+cu118 \
      --extra-index-url https://download.pytorch.org/whl/cu118 && \
    echo "✓ PyTorch 安装完成"

RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 10.4] 安装科学计算库" && \
    echo "========================================" && \
    echo "包括: numpy, scipy, scikit-learn" && \
    echo "注意: 使用 --ignore-installed 跳过系统预装包" && \
    echo "" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      numpy==1.24.4 && \
    echo "✓ numpy 安装完成" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      scipy==1.10.1 && \
    echo "✓ scipy 安装完成" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      scikit-learn==1.3.2 && \
    echo "✓ scikit-learn 安装完成"

RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 10.5] 安装点云处理库 (重点)" && \
    echo "========================================" && \
    echo "预计下载大小: ~400 MB" && \
    echo "预计安装时间: 3-5 分钟" && \
    echo "" && \
    pip3 install --no-cache-dir --ignore-installed "pillow>=9.3.0" && \
    echo "✓ pillow 安装完成" && \
    echo "" && \
    echo "开始下载 open3d (最大包, 耐心等待...)" && \
    pip3 install --no-cache-dir --retries 5 --timeout 600 --ignore-installed \
      open3d==0.18.0 && \
    echo "✓ open3d 安装完成" && \
    echo "" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      faiss-cpu==1.7.4 && \
    echo "✓ faiss-cpu 安装完成"
RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 10.6] 安装 OverlapTransformer 依赖" && \
    echo "========================================" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      matplotlib && \
    echo "✓ matplotlib 安装完成" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      opencv-python-headless && \
    echo "✓ opencv-python-headless 安装完成" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      pyyaml && \
    echo "✓ pyyaml 安装完成" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      tqdm && \
    echo "✓ tqdm 安装完成" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      tensorboard && \
    echo "✓ tensorboard 安装完成"

RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 10.7] 安装评估与几何工具" && \
    echo "========================================" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      evo==1.28.0 && \
    echo "✓ evo 安装完成" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      transforms3d && \
    echo "✓ transforms3d 安装完成" && \
    pip3 install --no-cache-dir --retries 5 --timeout 300 --ignore-installed \
      trimesh && \
    echo "✓ trimesh 安装完成"

RUN echo "" && \
    echo "========================================" && \
    echo "[阶段 10.8] 尝试安装 faiss-gpu (可选)" && \
    echo "========================================" && \
    echo "注意: 如安装失败将自动跳过,使用 faiss-cpu 替代" && \
    echo "" && \
    pip3 install --no-cache-dir faiss-gpu==1.7.2 && \
    echo "✓ faiss-gpu 安装成功" || \
    echo "⚠ faiss-gpu 安装失败 (正常),使用 faiss-cpu"

# ==========================================================================
# 12. 环境配置
# ==========================================================================

# CycloneDDS 大数据量优化配置
RUN mkdir -p /etc/cyclonedds && \
    cat > /etc/cyclonedds/cyclonedds.xml << 'EOF'
<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config
            https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
  <Domain>
    <General>
      <AllowMulticast>true</AllowMulticast>
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>
    <Internal>
      <SocketReceiveBufferSize min="10MB"/>
      <Watermarks>
        <WhcHigh>500kB</WhcHigh>
      </Watermarks>
    </Internal>
  </Domain>
</CycloneDDS>
EOF

# Shell 环境
RUN cat >> /root/.bashrc << 'BASHEOF'

# === ROS2 ===
source /opt/ros/humble/setup.bash

# === DDS ===
export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
export CYCLONEDDS_URI=file:///etc/cyclonedds/cyclonedds.xml

# === CUDA ===
export CUDA_HOME=/usr/local/cuda
export PATH=$CUDA_HOME/bin:$PATH
export LD_LIBRARY_PATH=$CUDA_HOME/lib64:$LD_LIBRARY_PATH

# === 自动 source 工作空间 (挂载后) ===
if [ -f /root/automap_ws/install/setup.bash ]; then
  source /root/automap_ws/install/setup.bash
fi

BASHEOF

# ldconfig 确保所有库可被找到
RUN echo "" && \
    echo "========================================" && \
    echo "[最终阶段] 环境验证" && \
    echo "========================================" && \
    echo "运行 ldconfig 更新库缓存..." && \
    ldconfig && \
    echo "✓ 库缓存更新完成" && \
    echo "" && \
    echo "验证核心依赖:" && \
    echo "  - Python: $(python3 --version)" && \
    echo "  - PyTorch: $(python3 -c 'import torch; print(torch.__version__)')" && \
    echo "  - CUDA: $(python3 -c 'import torch; print(torch.version.cuda)')" && \
    echo "  - Open3D: $(python3 -c 'import open3d; print(open3d.__version__)')" && \
    echo "  - GTSAM: $(pkg-config --modversion gtsam 2>/dev/null || echo '已安装')" && \
    echo "✓ 核心依赖验证完成" && \
    echo "" && \
    echo "========================================" && \
    echo "✓ Docker 镜像构建完成!" && \
    echo "========================================"

# 补装 nlohmann_json（放在最后以减小重建范围，避免动前面大层）
RUN apt-get update && \
    apt-get install -y --no-install-recommends nlohmann-json3-dev && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /root

CMD ["/bin/bash"]